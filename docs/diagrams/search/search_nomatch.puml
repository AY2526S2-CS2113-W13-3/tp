@startuml
actor User
participant JobPilot
participant "ArrayList<Application>" as AppList
participant Application
User -> JobPilot : input "search p/nonexistent"
JobPilot -> JobPilot : search(type="p", query="nonexistent")
loop for each application
    JobPilot -> Application : getPosition()
    Application --> JobPilot : position
    JobPilot -> JobPilot : contains(query)?
end
alt no matches found
    JobPilot -> User : "No applications found for position: nonexistent"
else matches found
    JobPilot -> User : display results
end
@enduml